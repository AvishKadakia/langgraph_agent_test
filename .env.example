# ─────────────────────────────────────────────────────────────────────────
# Agent QA Eval Suite — configuration
# The launcher (run.command / run.bat) and `make setup` copy this to .env.
# ─────────────────────────────────────────────────────────────────────────

# The agent API to test (base URL, no trailing /chat). Authenticates with your
# `az login` — run `az login` once and you're set.
CHAT_API_URL=https://langraph-agent-orchestration.mangocliff-b6d9609f.eastus2.azurecontainerapps.io

# Entra scope used to mint the agent token from your `az login`.
CHAT_API_SCOPE=api://c7f3f79e-622a-4344-acd4-43a42349fcd1/.default

# Default sheet name to read in uploaded workbooks (overridable in the UI).
DEFAULT_SHEET=Intent Test Cases

# ── LLM judge (Azure OpenAI) ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://test-project-ak-resource.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-chat-latest
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Leave blank to authenticate the judge with your az login (AAD). Set a key only
# if your account lacks the "Cognitive Services OpenAI User" role.
AZURE_OPENAI_API_KEY=

# Port the UI is served on.
APP_PORT=8080
